# Rust 构建产物
/target/
**/target/

# Cargo 锁文件按需提交（workspace 根的 Cargo.lock 应提交）
**/*.rs.bk
*.pdb

# IDE 与编辑器
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.trae/

# 本地配置
.env
.env.local
*.local.toml
examples/18_harness/config.yaml

# 临时目录（删除文件 mv 目标）
/.trash/
/tmp/

# 测试输出
/coverage/
/tarpaulin-report.html
/test-results/
/bench-results.txt

# Python（axon-pyo3 后续阶段使用）
__pycache__/
*.pyc
.venv/
venv/

# 日志
*.log
logs/

# proptest 回归案例(由 proptest 自动管理,不进入版本控制)
**/proptest-regressions/

Cargo.lock

# Python 包(axon_quant)构建产物 — 源码仍需进版本控制,只忽略产物
# 见 `make python-clean` 与 `python/axon_quant/*.so` / `__pycache__` / `_native*.so`
python/axon_quant/*.so
python/axon_quant/_native*.so
python/axon_quant/__pycache__/
python/axon_quant/*/__pycache__/
# mkdocs 临时产物(由 `make docs-build` 生成的静态站点与缓存)
# 部署由 .github/workflows/docs.yml 处理,本地 site/ 不进版本控制
/site/
/.cache/
docs/en/report/*
docs/zh/report/*
.axon-internal/*
.mimocode/*
.codegraph/*
uv.lock
